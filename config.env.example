# Copy this file to .env and fill in the values. .env is gitignored.
# Loaded by start_all.py on the host and by the backend container via docker-compose.

# -----------------------------------------------------------------------------
# Postgres (used to build DATABASE_URL for backend and setup scripts)
# -----------------------------------------------------------------------------
POSTGRES_USER=zalpha
POSTGRES_PASSWORD=zalpha
POSTGRES_DB=zalpha

# -----------------------------------------------------------------------------
# IBKR TWS (runs on the host because of 2FA; backend reaches it via host.docker.internal)
# -----------------------------------------------------------------------------
IBKR_HOST=127.0.0.1
IBKR_PORT=7496           # 7496 = live TWS, 7497 = paper TWS, 4001 = IB Gateway
IBKR_CLIENT_ID=1
IBKR_TIMEOUT=20

# -----------------------------------------------------------------------------
# Seed credentials for the two built-in users (admin + analyst).
# These are created on first DB seed and verified via bcrypt on login.
# Passwords must be at least 8 characters.
# -----------------------------------------------------------------------------
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@zalpha.local
ADMIN_PASSWORD=change-me-admin

USER_USERNAME=user
USER_EMAIL=user@zalpha.local
USER_PASSWORD=change-me-user

# -----------------------------------------------------------------------------
# Secret used to sign session tokens issued by /login.
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
# -----------------------------------------------------------------------------
AUTH_SECRET=replace-with-random-48-chars-or-more
